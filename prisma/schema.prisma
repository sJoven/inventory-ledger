datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String            @id @default(uuid())
  name              String?
  email             String?           @unique
  emailVerified     DateTime?
  image             String?
  is_client         String[]          
  accounts          Account[]
  logs              ActivityLog[]
  owned_stores      Store[]           @relation("StoreOwner")
  store_permissions StorePermission[]
  carts             Cart[]
  orders            Order[]

  @@map("users")
}

model StorePermission {
  id        String  @id @default(uuid())
  user_id   String
  user      User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store_id  String
  role      String
  is_active Boolean @default(true)

  @@map("store_permissions")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text 
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Store {
  id         String         @id @default(uuid())
  store_name String
  owner_id   String
  owner      User           @relation("StoreOwner", fields: [owner_id], references: [id])
  version    Int            @default(0)
  settings   StoreSettings? 
  products   Product[]
  logs       ActivityLog[]
  carts      Cart[]
  orders     Order[]

  @@map("stores")
}

model StoreSettings {
  id                       String  @id @default(uuid())
  store_id                 String  @unique
  store                    Store   @relation(fields: [store_id], references: [id], onDelete: Cascade)
  low_stock_threshold      Int     @default(10)
  currency                 String  @default("PHP")
  theme                    String  @default("light")
  allow_negative_inventory Boolean @default(false)
  store_icon               String?

  @@map("store_settings")
}

model Product {
  id          String  @id @default(uuid())
  store_id    String
  sku         String
  name        String
  image       String
  description String
  quantity    Int     @default(0)
  price       Int     @default(0)
  version     Int     @default(0)
  is_deleted  Boolean @default(false)
  store       Store   @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id, sku])
  @@map("products")
}

model ActivityLog {
  id         String   @id @default(uuid())
  store_id   String
  user_id    String
  action     String
  doc_id     String
  prev_state Json?    
  createdAt  DateTime @default(now())
  store      Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id])

  @@index([store_id, createdAt])
  @@map("activity_logs")
}

model Cart {
  id         String     @id @default(uuid())
  user_id    String
  store_id   String
  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store      Store      @relation(fields: [store_id], references: [id], onDelete: Cascade)
  items      CartItem[]
  updated_at DateTime   @updatedAt

  @@unique([user_id, store_id])
  @@map("carts")
}

model CartItem {
  id         String @id @default(uuid())
  cart_id    String
  cart       Cart   @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product_id String
  quantity   Int    @default(1)

  @@map("cart_items")
}

model Order {
  id            String       @id @default(uuid())
  createdAt     DateTime     @default(now())
  transactionid String       @unique
  ordernum      String       @unique
  
  store_id      String
  store         Store        @relation(fields: [store_id], references: [id], onDelete: Cascade)
  
  customerid    String
  customer      User         @relation(fields: [customerid], references: [id])
  
  items         OrderItem[]
  totalPrice    Int          
  payment       PaymentInfo? 

  @@index([store_id, createdAt])
  @@map("orders")
}

model OrderItem {
  id          String @id @default(uuid())
  order_id    String
  order       Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  productid   String
  productname String
  quantity    Int

  @@map("order_items")
}

model PaymentInfo {
  id                String @id @default(uuid())
  order_id          String @unique
  order             Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  customerPaymentId String
  method            String
  status            String

  @@map("payment_info")
}